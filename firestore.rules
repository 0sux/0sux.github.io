rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdminEmail() {
      return signedIn() && request.auth.token.email in ['official0warn@gmail.com'];
    }

    function privateProfile(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid));
    }

    function isAdmin() {
      return signedIn() && (
        bootstrapAdminEmail() ||
        (
          exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          privateProfile(request.auth.uid).data.role == 'admin'
        )
      );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /profiles/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == (bootstrapAdminEmail() ? 'admin' : 'user');
      allow read, delete: if isOwner(uid) || isAdmin();
      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
        );
    }

    match /public_profiles/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
        && request.resource.data.role == (isAdmin() ? 'admin' : 'user');
      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.role == resource.data.role
        );
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /blog_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /video_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /forum_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /forum_threads/{threadId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid)
        || (
          signedIn()
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.categoryId == resource.data.categoryId
          && request.resource.data.title == resource.data.title
          && request.resource.data.content == resource.data.content
          && request.resource.data.isPinned == resource.data.isPinned
          && request.resource.data.isLocked == resource.data.isLocked
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'replies', 'lastActivityAt'])
        );
      allow delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    match /forum_replies/{replyId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    match /site_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
